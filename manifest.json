{
  "manifest_version": 3,
  "name": "WhatsApp Contact Extractor",
  "version": "1.0",
  "description": "Extract contact numbers from WhatsApp groups",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WhatsApp Contact Extractor"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}